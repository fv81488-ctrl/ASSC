    lines.forEach((l,i)=>ctx.fillText(l, cp.x, cp.y-4+(i-lines.length/2+0.7)*13));
    ctx.textAlign='left';
  });

  // RF waves from antennas
  if(SIM.tx) {
    [compsPos.ant1, compsPos.ant2].forEach((ant,bi)=>{
      for(let i=1;i<=5;i++){
        const r = ant.r + i*18 + (Date.now()/50 % 18);
        const alpha = Math.max(0, 0.5-i*0.1);
        ctx.strokeStyle=`rgba(201,168,76,${alpha})`;
        ctx.lineWidth=1;
        ctx.beginPath(); ctx.arc(ant.x,ant.y,r,0,Math.PI*2); ctx.stroke();
      }
      // Frequency label
      ctx.fillStyle='#c9a84c'; ctx.font='bold 10px JetBrains Mono'; ctx.textAlign='center';
      ctx.fillText(SIM.band===bi ? `▶ ${SIM.freq[bi].toFixed(1)} MHz` : `${SIM.freq[bi].toFixed(1)} MHz`,
        ant.x, ant.y+ant.r+22);
      ctx.textAlign='left';
    });
  }

  // Status overlay
  ctx.fillStyle='rgba(4,6,13,0.7)'; ctx.fillRect(8,8,200,32);
  ctx.strokeStyle='rgba(201,168,76,0.4)'; ctx.lineWidth=1; ctx.strokeRect(8,8,200,32);
  ctx.fillStyle='#c9a84c'; ctx.font='bold 10px JetBrains Mono';
  ctx.fillText(`G-80 · ${SIM.tx?'⚡ TX':'● STANDBY'} · ${SIM.freq[SIM.band].toFixed(1)} MHz`, 15, 28);
}

function hexToRgbaS(hex, a) {
  const r=parseInt(hex.slice(1,3),16), g=parseInt(hex.slice(3,5),16), b=parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${a})`;
