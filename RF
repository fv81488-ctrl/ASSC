    ctx.fillStyle=hexToRgbaS(cp.c, active?0.3:0.12);
    ctx.beginPath(); ctx.arc(cp.x,cp.y,cp.r,0,Math.PI*2); ctx.fill();
    ctx.strokeStyle=cp.c; ctx.lineWidth=active?2.5:1.5;
