<!DOCTYPE html>

<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>G-80 RF Dual-Band — محاكاة الدائرة الكاملة</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;900&family=JetBrains+Mono:wght@300;400;700&display=swap');
:root {
  --bg:#04060d; --panel:#080d1a; --card:#0c1225; --border:#1a2a45;
  --gold:#c9a84c; --gold2:#e8d08a; --green:#00c853; --green2:#69f0ae;
  --red:#ff1744; --amber:#ff9800; --cyan:#00bcd4; --blue:#1565c0;
  --purple:#7c4dff; --pink:#f50057; --text:#dce8f5; --muted:#6a7f9a;
  --esp:#ffd700; --rf:#00bcd4; --crypto:#7c4dff; --audio:#ff9800;
  --display:#00e676; --power:#ff5722;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'Tajawal',sans-serif;min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background:repeating-linear-gradient(0deg,rgba(0,200,83,.008)0,transparent 2px,transparent 4px),
  radial-gradient(ellipse 60% 50% at 15% 15%,rgba(0,188,212,.06)0,transparent 60%),
  radial-gradient(ellipse 50% 60% at 85% 85%,rgba(124,77,255,.05)0,transparent 60%)}

/* HEADER */
header{position:sticky;top:0;z-index:100;background:rgba(4,6,13,.95);backdrop-filter:blur(20px);
border-bottom:1px solid var(–border);padding:0 1.5rem}
.hdr{display:flex;align-items:center;justify-content:space-between;height:60px;max-width:1800px;margin:0 auto;gap:1rem}
.htitle{font-size:1rem;font-weight:900;color:var(–gold);font-family:‘JetBrains Mono’,monospace;letter-spacing:.05em}
.hsub{font-size:.68rem;color:var(–muted)}
.tabs{display:flex;gap:4px;background:rgba(255,255,255,.04);border-radius:10px;padding:4px}
.tab{padding:6px 16px;border-radius:7px;border:none;background:transparent;color:var(–muted);
cursor:pointer;font-family:‘Tajawal’,sans-serif;font-size:.82rem;transition:all .2s}
.tab.active{background:var(–gold);color:#000;font-weight:700}
.tab:hover:not(.active){color:var(–text);background:rgba(255,255,255,.06)}

/* MAIN */
main{max-width:1800px;margin:0 auto;padding:1.2rem;position:relative;z-index:1}
.page{display:none}.page.active{display:block;animation:fadeIn .3s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* CARDS */
.card{background:var(–card);border:1px solid var(–border);border-radius:14px;padding:1.2rem;position:relative;overflow:hidden}
.card::before{content:’’;position:absolute;inset:0;border-radius:14px;
background:linear-gradient(135deg,rgba(201,168,76,.02)0,transparent 50%);pointer-events:none}
.ctitle{font-size:.78rem;font-weight:700;color:var(–gold);letter-spacing:.06em;text-transform:uppercase;
margin-bottom:1rem;display:flex;align-items:center;gap:7px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem}
@media(max-width:900px){.grid2,.grid3{grid-template-columns:1fr}}

/* SCHEMATIC CANVAS */
#sch-canvas{width:100%;height:600px;border-radius:12px;cursor:crosshair;display:block}
.sch-wrap{background:#fafbfc;border-radius:12px;position:relative;border:2px solid var(–border)}
.sch-overlay{position:absolute;inset:0;border-radius:12px;pointer-events:none}
.err-badge{position:absolute;background:rgba(255,23,68,.9);color:#fff;font-size:.62rem;
font-weight:700;padding:2px 6px;border-radius:4px;cursor:pointer;pointer-events:all;
animation:errPulse 1.5s infinite;font-family:‘JetBrains Mono’,monospace}
.fix-badge{position:absolute;background:rgba(0,200,83,.9);color:#000;font-size:.62rem;
font-weight:700;padding:2px 6px;border-radius:4px;pointer-events:all;font-family:‘JetBrains Mono’,monospace}
@keyframes errPulse{0%,100%{box-shadow:0 0 0 0 rgba(255,23,68,.6)}50%{box-shadow:0 0 0 6px rgba(255,23,68,0)}}

/* SIMULATION CANVAS */
#sim-canvas{width:100%;height:560px;border-radius:12px;display:block;cursor:pointer}

/* COMPONENT INFO */
.comp-info{background:var(–panel);border:1px solid var(–border);border-radius:10px;padding:1rem;font-size:.8rem}
.comp-name{font-size:1rem;font-weight:700;color:var(–gold);margin-bottom:.5rem}
.comp-row{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid rgba(255,255,255,.04)}
.comp-row:last-child{border-bottom:none}
.comp-key{color:var(–muted);font-size:.75rem}
.comp-val{color:var(–text);font-size:.75rem;font-family:‘JetBrains Mono’,monospace;font-weight:700}

/* ERROR LIST */
.err-list{display:flex;flex-direction:column;gap:.6rem;max-height:400px;overflow-y:auto}
.err-item{display:flex;gap:10px;padding:10px 12px;border-radius:8px;border-left:3px solid}
.err-item.err{border-color:var(–red);background:rgba(255,23,68,.06)}
.err-item.fix{border-color:var(–green);background:rgba(0,200,83,.06)}
.err-item.warn{border-color:var(–amber);background:rgba(255,152,0,.06)}
.err-item.add{border-color:var(–cyan);background:rgba(0,188,212,.06)}
.err-ico{font-size:1.1rem;flex-shrink:0}
.err-title{font-weight:700;font-size:.82rem;margin-bottom:2px}
.err-item.err .err-title{color:var(–red)}
.err-item.fix .err-title{color:var(–green)}
.err-item.warn .err-title{color:var(–amber)}
.err-item.add .err-title{color:var(–cyan)}
.err-desc{font-size:.73rem;color:var(–muted);line-height:1.6}

/* SIGNAL PATH */
.sig-path{display:flex;align-items:center;gap:0;flex-wrap:wrap;margin:1rem 0}
.sig-block{padding:8px 14px;border-radius:8px;font-size:.75rem;font-weight:700;text-align:center;
position:relative;min-width:90px;cursor:pointer;transition:all .2s}
.sig-block:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.4)}
.sig-arrow{font-size:.9rem;color:var(–muted);margin:0 4px;flex-shrink:0}
.sig-block.mic{background:rgba(255,152,0,.15);border:1px solid var(–amber);color:var(–amber)}
.sig-block.adc{background:rgba(255,87,34,.15);border:1px solid var(–power);color:var(–power)}
.sig-block.codec{background:rgba(255,215,0,.15);border:1px solid var(–esp);color:var(–esp)}
.sig-block.enc{background:rgba(124,77,255,.15);border:1px solid var(–purple);color:var(–purple)}
.sig-block.pll{background:rgba(0,188,212,.15);border:1px solid var(–cyan);color:var(–cyan)}
.sig-block.pa{background:rgba(0,200,83,.15);border:1px solid var(–green);color:var(–green)}
.sig-block.ant{background:rgba(201,168,76,.15);border:1px solid var(–gold);color:var(–gold)}
.sig-block.spk{background:rgba(255,152,0,.15);border:1px solid var(–amber);color:var(–amber)}
.sig-block.disp{background:rgba(0,230,118,.15);border:1px solid var(–display);color:var(–display)}

/* FREQ DISPLAY */
.freq-dial{background:rgba(0,0,0,.4);border:1px solid var(–border);border-radius:10px;padding:1.2rem;text-align:center}
.freq-num{font-family:‘JetBrains Mono’,monospace;font-size:2rem;font-weight:700;line-height:1}
.freq-unit{font-size:.8rem;color:var(–muted);margin-top:4px}
.freq-bar{height:4px;border-radius:2px;margin-top:12px;background:linear-gradient(90deg,var(–cyan),var(–green))}

/* WAVEFORM */
#wave-canvas{width:100%;height:120px;border-radius:8px;background:rgba(0,0,0,.4)}
#enc-canvas{width:100%;height:120px;border-radius:8px;background:rgba(0,0,0,.4)}
#fhss-canvas{width:100%;height:100px;border-radius:8px;background:rgba(0,0,0,.4)}

/* CONTROLS */
.ctrl-btn{padding:8px 18px;border-radius:8px;border:1px solid;cursor:pointer;font-family:‘Tajawal’,sans-serif;
font-size:.82rem;transition:all .2s}
.btn-grn{border-color:var(–green);background:rgba(0,200,83,.1);color:var(–green)}
.btn-grn:hover{background:rgba(0,200,83,.25)}
.btn-red{border-color:var(–red);background:rgba(255,23,68,.1);color:var(–red)}
.btn-red:hover{background:rgba(255,23,68,.25)}
.btn-cyan{border-color:var(–cyan);background:rgba(0,188,212,.1);color:var(–cyan)}
.btn-cyan:hover{background:rgba(0,188,212,.25)}
.btn-gold{border-color:var(–gold);background:rgba(201,168,76,.1);color:var(–gold)}
.btn-gold:hover{background:rgba(201,168,76,.25)}

/* STATUS PILLS */
.pill{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:100px;
font-size:.7rem;font-weight:700;border:1px solid;font-family:‘JetBrains Mono’,monospace}
.pg{border-color:var(–green);color:var(–green);background:rgba(0,200,83,.08)}
.pc{border-color:var(–cyan);color:var(–cyan);background:rgba(0,188,212,.08)}
.pp{border-color:var(–purple);color:var(–purple);background:rgba(124,77,255,.08)}
.pa2{border-color:var(–amber);color:var(–amber);background:rgba(255,152,0,.08)}
.pdot{width:5px;height:5px;border-radius:50%;background:currentColor;animation:blink 1.3s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* DEVICE MOCKUP */
.device-frame{background:linear-gradient(145deg,#1a1a2e,#16213e);border:3px solid #2a2a4e;
border-radius:20px;padding:12px;width:280px;margin:0 auto;position:relative;
box-shadow:0 20px 60px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.05)}
.device-screen{background:#000;border-radius:12px;overflow:hidden;aspect-ratio:16/9;
border:2px solid #111;position:relative}
.device-antenna{width:4px;height:40px;background:linear-gradient(to top,#666,#aaa);
border-radius:2px;position:absolute;top:-45px;right:20px}
.device-btn{width:20px;height:20px;background:var(–gold);border-radius:50%;
position:absolute;right:-12px;top:50%;transform:translateY(-50%);
box-shadow:0 0 10px var(–gold);cursor:pointer;border:none}
.device-btn:active{box-shadow:0 0 20px var(–gold)}
.device-speaker{width:60px;height:6px;background:repeating-linear-gradient(90deg,#333 0,#333 3px,transparent 3px,transparent 6px);
border-radius:3px;margin:8px auto 0}
.device-mic{width:6px;height:6px;background:#333;border-radius:50%;position:absolute;bottom:6px;left:50%;transform:translateX(-50%)}

/* SCREEN CONTENT */
.screen-ui{padding:6px;color:#0f0;font-family:‘JetBrains Mono’,monospace;font-size:.6rem;height:100%;
background:linear-gradient(135deg,#000810,#001020)}
.screen-line{padding:1px 0;border-bottom:1px solid rgba(0,255,0,.05)}
.screen-header{color:var(–gold);font-weight:700;font-size:.65rem;text-align:center;padding:3px 0;
border-bottom:1px solid rgba(201,168,76,.2);margin-bottom:4px}
#screen-status{color:var(–green)}
#screen-freq{color:var(–cyan)}
#screen-enc{color:var(–purple)}
#screen-rssi{color:var(–amber)}
#screen-batt{color:var(–green2)}

/* SPEC TABLE */
.spec-table{width:100%;border-collapse:collapse}
.spec-table th{padding:8px 12px;text-align:right;font-size:.72rem;color:var(–muted);
border-bottom:1px solid var(–border);background:rgba(0,0,0,.3);font-family:‘JetBrains Mono’,monospace;text-transform:uppercase}
.spec-table td{padding:9px 12px;font-size:.78rem;border-bottom:1px solid rgba(26,42,69,.4);vertical-align:middle}
.spec-table tr:hover td{background:rgba(255,255,255,.02)}
.spec-comp{font-weight:700;color:var(–text)}
.spec-id{font-family:‘JetBrains Mono’,monospace;font-size:.7rem;color:var(–gold)}
.spec-desc{color:var(–muted);font-size:.73rem}
.tag{display:inline-block;padding:2px 8px;border-radius:100px;font-size:.65rem;font-weight:700;margin:1px}
.tg{background:rgba(0,200,83,.15);color:var(–green);border:1px solid rgba(0,200,83,.3)}
.tr{background:rgba(255,23,68,.15);color:var(–red);border:1px solid rgba(255,23,68,.3)}
.tc{background:rgba(0,188,212,.15);color:var(–cyan);border:1px solid rgba(0,188,212,.3)}
.tp{background:rgba(124,77,255,.15);color:var(–purple);border:1px solid rgba(124,77,255,.3)}
.ta{background:rgba(255,152,0,.15);color:var(–amber);border:1px solid rgba(255,152,0,.3)}

::-webkit-scrollbar{width:5px}::-webkit-scrollbar-thumb{background:var(–border);border-radius:3px}
</style>

</head>
<body>

<header>
<div class="hdr">
  <div>
    <div class="htitle">⚡ G-80 RF DUAL-BAND — محاكاة الدائرة الكاملة</div>
    <div class="hsub">ADF4352 + ESP32-S3 + ATECC608A · ترددين · تشفير عتادي</div>
  </div>
  <div class="tabs">
    <button class="tab active" onclick="showPage('schematic')">📐 المخطط المُصحَّح</button>
    <button class="tab" onclick="showPage('simulation')">⚡ المحاكاة الحية</button>
    <button class="tab" onclick="showPage('errors')">🔴 الأخطاء والإصلاح</button>
    <button class="tab" onclick="showPage('specs')">📋 المواصفات</button>
  </div>
  <div style="display:flex;gap:6px;flex-wrap:wrap">
    <span class="pill pg"><span class="pdot"></span>نشط</span>
    <span class="pill pc">ADF4352</span>
    <span class="pill pp">AES-GCM</span>
  </div>
</div>
</header>

<main>

<!-- ════ PAGE 1: SCHEMATIC ════ -->

<div class="page active" id="page-schematic">
  <div style="display:grid;grid-template-columns:1fr 340px;gap:1.2rem;align-items:start">
    <div class="card">
      <div class="ctitle">📐 المخطط الكهربائي المُصحَّح والمُطوَّر</div>
      <div class="sch-wrap">
        <canvas id="sch-canvas"></canvas>
        <div class="sch-overlay" id="schOverlay"></div>
      </div>
      <div style="display:flex;gap:.6rem;flex-wrap:wrap;margin-top:.8rem">
        <button class="ctrl-btn btn-grn" onclick="toggleFixes()">✓ إظهار الإصلاحات</button>
        <button class="ctrl-btn btn-red" onclick="toggleErrors()">✕ إظهار الأخطاء</button>
        <button class="ctrl-btn btn-cyan" onclick="animateSignal()">▶ تحريك الإشارة</button>
        <button class="ctrl-btn btn-gold" onclick="resetSchematic()">↺ إعادة ضبط</button>
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:1rem">
      <div class="comp-info" id="compInfo">
        <div class="comp-name">🖱️ انقر على مكوّن</div>
        <div style="color:var(--muted);font-size:.75rem">انقر على أي مكوّن في المخطط لعرض تفاصيله الفنية</div>
      </div>
      <div class="card">
        <div class="ctitle">🎯 المكونات الرئيسية</div>
        <div style="display:flex;flex-direction:column;gap:.5rem;font-size:.75rem">
          <div onclick="showComp('esp32')" style="cursor:pointer;padding:6px 10px;border-radius:7px;background:rgba(255,215,0,.08);border:1px solid rgba(255,215,0,.2);color:var(--esp)">🟡 U9 — ESP32-S3 (المعالج الرئيسي)</div>
          <div onclick="showComp('adf')" style="cursor:pointer;padding:6px 10px;border-radius:7px;background:rgba(0,188,212,.08);border:1px solid rgba(0,188,212,.2);color:var(--cyan)">🔵 U7 — ADF4352 (مُولِّد التردد PLL)</div>
          <div onclick="showComp('atec')" style="cursor:pointer;padding:6px 10px;border-radius:7px;background:rgba(124,77,255,.08);border:1px solid rgba(124,77,255,.2);color:var(--purple)">🟣 U1 — ATECC608A (تشفير عتادي)</div>
          <div onclick="showComp('maam')" style="cursor:pointer;padding:6px 10px;border-radius:7px;background:rgba(0,200,83,.08);border:1px solid rgba(0,200,83,.2);color:var(--green)">🟢 U6 — MAAM-007221 (مُضخِّم MMIC)</div>
          <div onclick="showComp('sky')" style="cursor:pointer;padding:6px 10px;border-radius:7px;background:rgba(255,87,34,.08);border:1px solid rgba(255,87,34,.2);color:var(--power)">🟠 U5 — SKY65404 (مبدِّل RF)</div>
          <div onclick="showComp('mic')" style="cursor:pointer;padding:6px 10px;border-radius:7px;background:rgba(255,152,0,.08);border:1px solid rgba(255,152,0,.2);color:var(--amber)">🟡 MIC — INMP441 (ميكروفون I2S) ★جديد</div>
          <div onclick="showComp('spk')" style="cursor:pointer;padding:6px 10px;border-radius:7px;background:rgba(255,152,0,.08);border:1px solid rgba(255,152,0,.2);color:var(--amber)">🔊 U10 — MAX98357A (مكبر صوت) ★جديد</div>
          <div onclick="showComp('disp')" style="cursor:pointer;padding:6px 10px;border-radius:7px;background:rgba(0,230,118,.08);border:1px solid rgba(0,230,118,.2);color:var(--display)">📺 LCD — ST7789V (شاشة TFT) ★جديد</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ════ PAGE 2: SIMULATION ════ -->

<div class="page" id="page-simulation">
  <div style="display:grid;grid-template-columns:1fr 300px;gap:1.2rem">
    <div>
      <div class="card" style="margin-bottom:1rem">
        <div class="ctitle">⚡ محاكاة الدائرة الحية</div>
        <canvas id="sim-canvas" onclick="toggleTransmit()"></canvas>
        <div style="display:flex;gap:.6rem;margin-top:.8rem;flex-wrap:wrap;align-items:center">
          <button class="ctrl-btn btn-grn" id="txBtn" onclick="toggleTransmit()">▶ إرسال</button>
          <button class="ctrl-btn btn-cyan" onclick="toggleBand()">🔄 تبديل التردد</button>
          <button class="ctrl-btn btn-purple" onclick="triggerEncrypt()" style="border-color:var(--purple);background:rgba(124,77,255,.1);color:var(--purple)">🔒 تشفير</button>
          <span id="txStatus" class="pill pg" style="display:none"><span class="pdot"></span>جارٍ الإرسال</span>
        </div>
      </div>

```
  <div class="grid2" style="margin-bottom:1rem">
    <div class="card">
      <div class="ctitle">🎵 الإشارة الصوتية (Codec2)</div>
      <canvas id="wave-canvas"></canvas>
      <div style="display:flex;justify-content:space-between;margin-top:.5rem;font-size:.7rem;font-family:'JetBrains Mono',monospace">
        <span style="color:var(--muted)">8 kHz · 16-bit · Mono</span>
        <span style="color:var(--amber)">1200 bps Codec2</span>
      </div>
