let showErr=true, showFix=true;
function toggleErrors(){ showErr=!showErr; SCH.showErrors=showErr; drawSchematic(); }
function toggleFixes(){ showFix=!showFix; SCH.showFixes=showFix; drawSchematic(); }
function resetSchematic(){ showErr=true; showFix=true; SCH.showErrors=true; SCH.showFixes=true; drawSchematic(); }

function animateSignal() {
  SCH.signalPos = 0; SCH.animating = true;
  const path = [{x:170,y:220},{x:250,y:220},{x:310,y:220},{x:465,y:220},
                {x:490,y:220},{x:550,y:200},{x:585,y:260},{x:700,y:90}];
  let i = 0;
  function step() {
    if(i >= path.length-1){ SCH.animating=false; return; }
    const from=path[i], to=path[i+1];
    drawSchematic();
    const c = schCtx;
    c.strokeStyle='rgba(255,255,0,0.9)'; c.lineWidth=3; c.setLineDash([6,3]);
    c.beginPath(); c.moveTo(from.x,from.y); c.lineTo(to.x,to.y); c.stroke();
    c.setLineDash([]);
    c.fillStyle='#ffff00'; c.beginPath(); c.arc(to.x,to.y,5,0,Math.PI*2); c.fill();
    i++; setTimeout(step, 300);
  }
  step();
}

