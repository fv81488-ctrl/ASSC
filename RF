function drawArrow(c, x, y, dir, color) {
  c.fillStyle = color; c.beginPath();
  if(dir==='right'){c.moveTo(x,y-4);c.lineTo(x+8,y);c.lineTo(x,y+4)}
  else if(dir==='left'){c.moveTo(x,y-4);c.lineTo(x-8,y);c.lineTo(x,y+4)}
  else if(dir==='up'){c.moveTo(x-4,y);c.lineTo(x,y-8);c.lineTo(x+4,y)}
  c.closePath(); c.fill();
}

function drawComponents() {
  Object.entries(COMPS).forEach(([key,comp])=>{
    drawComp(comp, key);
  });
}

function drawComp(comp, key) {
  const c = schCtx, {x,y,w,h,color,label,sub} = comp;
  // Shadow
  c.fillStyle = 'rgba(0,0,0,0.15)';
  c.fillRect(x+3,y+3,w,h);
  // Fill
  c.fillStyle = hexToRgba(color, 0.12);
  c.fillRect(x,y,w,h);
  // Border
  c.strokeStyle = color; c.lineWidth = 1.5;
  c.setLineDash([]);
  // New components dashed border
  if(sub.includes('★')) { c.setLineDash([4,2]); c.lineWidth=2; }
  c.strokeRect(x,y,w,h);
  c.setLineDash([]);
  // Label
  c.fillStyle = '#111'; c.font = `bold ${Math.min(11, w/label.length*1.6)}px JetBrains Mono`;
  c.textAlign = 'center';
  c.fillText(label, x+w/2, y+h/2);
  c.font = '9px JetBrains Mono'; c.fillStyle = '#555';
  c.fillText(sub, x+w/2, y+h/2+13);
  // NEW badge
  if(sub.includes('★')) {
    c.fillStyle = '#00c853'; c.font = 'bold 8px sans-serif';
    c.fillText('NEW', x+w-18, y+10);
  }
  c.textAlign = 'left';
  // Click handler stored
  comp._bounds = {x,y,w,h};
}

