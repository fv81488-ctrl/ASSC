  <!-- Frequencies -->
  <div class="card">
    <div class="ctitle">📻 الترددان الفعليان</div>
    <div class="freq-dial" style="margin-bottom:.7rem">
      <div class="freq-num" id="freq1Num" style="color:var(--cyan)">868.0</div>
      <div class="freq-unit">MHz — النطاق الأول (LoRa EU ISM)</div>
      <div class="freq-bar" style="background:linear-gradient(90deg,var(--cyan),var(--blue))"></div>
    </div>
    <div class="freq-dial">
      <div class="freq-num" id="freq2Num" style="color:var(--green)">433.5</div>
