  for(let y=0;y<H;y+=40){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke()}

  // Component positions for simulation
  const cx = W*0.5, cy = H*0.5;
  const compsPos = {
    mic:   {x:W*.08, y:H*.25, r:30, c:'#ff9800', l:'🎙️\nINMP441'},
    esp:   {x:W*.22, y:H*.5,  r:45, c:'#ffd700', l:'⚙️\nESP32-S3'},
    atec:  {x:W*.22, y:H*.25, r:28, c:'#7c4dff', l:'🔒\nATECC'},
    adf:   {x:W*.45, y:H*.5,  r:40, c:'#00bcd4', l:'📡\nADF4352'},
    maam:  {x:W*.62, y:H*.35, r:28, c:'#00c853', l:'⚡\nMAMM'},
    sky:   {x:W*.62, y:H*.62, r:25, c:'#ff5722', l:'🔀\nSKY'},
    ant1:  {x:W*.82, y:H*.25, r:22, c:'#c9a84c', l:'📶\nAE1'},
    ant2:  {x:W*.82, y:H*.62, r:22, c:'#c9a84c', l:'📶\nAE2'},
    spk:   {x:W*.08, y:H*.72, r:28, c:'#ff9800', l:'🔊\nMAX98357'},
    lcd:   {x:W*.22, y:H*.8,  r:28, c:'#00e676', l:'📺\nST7789V'},
    tcxo:  {x:W*.45, y:H*.75, r:22, c:'#ff9800', l:'⏱️\nTCXO'},
  };

  // Draw connections
  const conns = [
    {from:'mic', to:'esp', c:'#ff9800', lbl:'I2S'},
    {from:'esp', to:'atec', c:'#7c4dff', lbl:'I2C'},
    {from:'esp', to:'adf', c:'#1565c0', lbl:'SPI'},
    {from:'esp', to:'spk', c:'#ff9800', lbl:'I2S'},
    {from:'esp', to:'lcd', c:'#00e676', lbl:'SPI'},
    {from:'adf', to:'maam', c:'#00bcd4', lbl:'RF'},
    {from:'adf', to:'sky', c:'#00bcd4', lbl:'RF'},
    {from:'maam', to:'ant1', c:'#c9a84c', lbl:'50Ω'},
    {from:'sky', to:'ant2', c:'#c9a84c', lbl:'50Ω'},
    {from:'tcxo', to:'adf', c:'#ff9800', lbl:'REF'},
  ];

  conns.forEach(conn=>{
    const f=compsPos[conn.from], t=compsPos[conn.to];
    const alpha = SIM.tx ? 0.8 : 0.3;
    ctx.strokeStyle=conn.c.replace(')',`,${alpha})`).replace('rgb','rgba'); 
    ctx.lineWidth = SIM.tx && (conn.lbl==='RF'||conn.lbl==='50Ω') ? 3 : 1.5;
    ctx.setLineDash(SIM.tx && conn.lbl==='I2S' ? [4,4] : []);
    ctx.beginPath(); ctx.moveTo(f.x,f.y); ctx.lineTo(t.x,t.y); ctx.stroke();
    ctx.setLineDash([]);

    // Animated signal particles on active conns
    if(SIM.tx) {
      const t2 = ((Date.now()/1000*2) % 1);
      const px = f.x + (t.x-f.x)*t2, py = f.y + (t.y-f.y)*t2;
      ctx.fillStyle = conn.c;
      ctx.beginPath(); ctx.arc(px,py,3,0,Math.PI*2); ctx.fill();
      ctx.shadowBlur=10; ctx.shadowColor=conn.c;
      ctx.beginPath(); ctx.arc(px,py,2,0,Math.PI*2); ctx.fill();
      ctx.shadowBlur=0;
    }

    // Label
    const mx=(f.x+t.x)/2, my=(f.y+t.y)/2;
