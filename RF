// ── WAVEFORM CANVAS ───────────────────────────────────────
function drawWaveform() {
  const cv = document.getElementById('wave-canvas'); if(!cv) return;
  const ctx = cv.getContext('2d');
  cv.width=cv.offsetWidth; cv.height=120;
  const W=cv.width, H=cv.height, mid=H/2;
  ctx.fillStyle='rgba(0,0,0,0.5)'; ctx.fillRect(0,0,W,H);
  // Grid lines
  ctx.strokeStyle='rgba(255,152,0,.1)'; ctx.lineWidth=.5;
  [H*.25, H*.5, H*.75].forEach(y=>{ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke()});

  ctx.strokeStyle = SIM.tx ? '#ff9800' : 'rgba(255,152,0,0.3)';
  ctx.lineWidth = 1.5; ctx.beginPath();
  const amp = SIM.tx ? 0.35 : 0.08;
  for(let x=0;x<W;x++){
    const t = x/W*4*Math.PI + wavePhase;
    const v = mid - (Math.sin(t)*0.6 + Math.sin(t*2.1)*0.25 + Math.sin(t*3.7)*0.15) * mid*amp;
    x===0 ? ctx.moveTo(x,v) : ctx.lineTo(x,v);
  }
  ctx.stroke();
  // Label
  ctx.fillStyle='rgba(255,152,0,0.7)'; ctx.font='9px JetBrains Mono';
  ctx.fillText(SIM.tx ? `Codec2 1200bps · Frame ${SIM.frame}` : 'IDLE — مستوى الضوضاء', 6, 14);
}

// ── ENCRYPTION WAVE ───────────────────────────────────────
function drawEncWave() {
  const cv = document.getElementById('enc-canvas'); if(!cv) return;
  const ctx = cv.getContext('2d');
  cv.width=cv.offsetWidth; cv.height=120;
  const W=cv.width, H=cv.height;
  ctx.fillStyle='rgba(0,0,0,0.5)'; ctx.fillRect(0,0,W,H);

  if(SIM.tx) {
    // Random-looking encrypted signal
    ctx.strokeStyle='#7c4dff'; ctx.lineWidth=1.5; ctx.beginPath();
    const seed = Math.floor(encPhase*10);
    for(let x=0;x<W;x+=2){
      const y = H/2 + (Math.sin(x*0.3+encPhase)*20 + Math.sin(x*0.7+encPhase*1.7)*15
               + Math.sin(x*1.3+encPhase*2.3)*10 + (Math.random()-0.5)*15);
      x===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    }
    ctx.stroke();
    // GCM tag animation
    const tagHex = Array(4).fill(0).map(()=>Math.floor(Math.random()*256).toString(16).padStart(2,'0').toUpperCase()).join('');
    document.getElementById('encTag').textContent = `Tag: 0x${tagHex}...`;
    ctx.fillStyle='rgba(124,77,255,0.15)'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='rgba(124,77,255,0.3)'; ctx.lineWidth=1;
    ctx.strokeRect(1,1,W-2,H-2);
  } else {
    ctx.fillStyle='rgba(124,77,255,0.1)'; ctx.fillRect(0,0,W,H);
    ctx.fillStyle='rgba(124,77,255,0.5)'; ctx.font='11px JetBrains Mono'; ctx.textAlign='center';
    ctx.fillText('AES-128-GCM · ATECC608A · مستعد', W/2, H/2+4); ctx.textAlign='left';
  }
  ctx.fillStyle='rgba(124,77,255,0.7)'; ctx.font='9px JetBrains Mono';
  ctx.fillText(SIM.tx?`AES-128-GCM · ECDH P-256 · Frame #${SIM.frame}`:'ATECC608A — محمي عتادياً', 6, 14);
}

// ── FHSS CANVAS ───────────────────────────────────────────
function drawFHSS() {
  const cv = document.getElementById('fhss-canvas'); if(!cv) return;
  const ctx = cv.getContext('2d');
  cv.width=cv.offsetWidth; cv.height=100;
  const W=cv.width, H=cv.height;
  ctx.fillStyle='rgba(0,0,0,0.5)'; ctx.fillRect(0,0,W,H);

  const bars=64, bw=W/bars;
  // Spectrum bars
  for(let i=0;i<bars;i++){
    const active = i===SIM.fhssCh;
    const noise = Math.random()*0.15;
    const h2 = (active?0.85:noise)*H*0.85;
    const g = ctx.createLinearGradient(0,H-h2,0,H);
    if(active){g.addColorStop(0,'rgba(255,23,68,1)');g.addColorStop(1,'rgba(255,23,68,0.2)')}
    else{g.addColorStop(0,`rgba(0,200,83,${noise*3})`);g.addColorStop(1,'rgba(0,200,83,0.05)')}
    ctx.fillStyle=g;
    ctx.fillRect(i*bw+0.5, H-h2, bw-1, h2);
  }

  // Active channel marker
  ctx.fillStyle='rgba(255,23,68,0.2)'; ctx.fillRect(SIM.fhssCh*bw,0,bw,H);
  ctx.strokeStyle='rgba(255,255,255,0.5)'; ctx.lineWidth=0.5;
  ctx.beginPath(); ctx.moveTo(0,H-1); ctx.lineTo(W,H-1); ctx.stroke();

  // Labels
  ctx.fillStyle='rgba(0,200,83,0.7)'; ctx.font='9px JetBrains Mono';
  const freq = (863 + SIM.fhssCh*0.1).toFixed(1);
  ctx.fillText(`CH-${SIM.fhssCh} · ${freq}MHz · FHSS LOCKED`, 6, 14);
}

// ── CONTROLS ─────────────────────────────────────────────
function toggleTransmit() {
  SIM.tx = !SIM.tx;
  const btn = document.getElementById('txBtn');
  const st  = document.getElementById('txStatus');
  if(SIM.tx){
    btn.textContent='⏹ إيقاف'; btn.classList.replace('btn-grn','btn-red');
    st.style.display='flex';
    startFHSSHopping();
  } else {
    btn.textContent='▶ إرسال'; btn.classList.replace('btn-red','btn-grn');
    st.style.display='none';
    if(SIM._hTimer){ clearInterval(SIM._hTimer); SIM._hTimer=null; }
  }
  updateScreenInfo();
}

function startFHSSHopping() {
  if(SIM._hTimer) clearInterval(SIM._hTimer);
  SIM._hTimer = setInterval(()=>{
    SIM.fhssCh = Math.floor(Math.random()*64);
    SIM.frame++;
  }, 600);
}

function toggleBand() {
  SIM.band = SIM.band===0?1:0;
  document.getElementById('freq1Num').style.fontWeight = SIM.band===0?'700':'400';
  document.getElementById('freq2Num').style.fontWeight = SIM.band===1?'700':'400';
}

function triggerEncrypt() {
  SIM.encPhase = (SIM.encPhase+1)%4;
  const el = document.getElementById('encTag');
  const hex = Array(8).fill(0).map(()=>Math.floor(Math.random()*256).toString(16).padStart(2,'0').toUpperCase()).join('');
  el.textContent = `Tag: 0x${hex}`;
}

function updateScreenInfo() {
  const f = (el,v) => { const e=document.getElementById(el); if(e)e.textContent=v; };
  f('screen-status', `● ${SIM.tx?'TX ACTIVE':'STANDBY'}`);
  f('screen-freq', `📡 FREQ: ${SIM.freq[SIM.band].toFixed(1)} MHz`);
  f('screen-enc', `🔒 AES-GCM: ${SIM.tx?'ENCRYPTING':'ARMED'}`);
  f('screen-rssi', `📶 RSSI: ${SIM.rssi} dBm`);
  f('screen-batt', `🔋 BATT: ${SIM.batt}%`);
  f('screen-ch', `⚡ CH: ${SIM.fhssCh} · ${SIM.tx?'HOPPING':'LOCKED'}`);
  f('screen-frames', `📦 FRAMES: ${SIM.frame}`);
}

function updateLiveStats() {
  SIM.rssi = -68 + Math.floor((Math.random()-0.5)*10);
  if(SIM.batt>10 && Math.random()<0.1) SIM.batt--;
  updateScreenInfo();
}

// ── INIT ────────────────────────────────────────────────
window.addEventListener('load', ()=>{
  drawSchematic();
  initSimulation();
});
window.addEventListener('resize', ()=>{ drawSchematic(); });
</script>

