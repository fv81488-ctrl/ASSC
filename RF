function drawSchematic() {
  schCanvas = document.getElementById('sch-canvas');
  if(!schCanvas) return;
  schCtx = schCanvas.getContext('2d');
  const W = schCanvas.offsetWidth;
  schCanvas.width = W; schCanvas.height = 600;
  schCtx.clearRect(0,0,W,600);
  drawBackground();
  drawWires();
  drawComponents();
  if(SCH.showErrors) drawErrors();
  if(SCH.showFixes) drawFixes();
}

