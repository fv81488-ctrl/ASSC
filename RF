document.getElementById('sch-canvas')?.addEventListener('click', e=>{
  const rect = schCanvas.getBoundingClientRect();
  const sx = (e.clientX - rect.left) * (schCanvas.width/rect.width);
  const sy = (e.clientY - rect.top) * (schCanvas.height/rect.height);
  Object.entries(COMPS).forEach(([key,comp])=>{
    if(sx>=comp.x && sx<=comp.x+comp.w && sy>=comp.y && sy<=comp.y+comp.h){
      showComp(key);
    }
  });
});

function showComp(key) {
  const comp = COMPS[key]; if(!comp||!comp.info) return;
  const info = comp.info;
  const el = document.getElementById('compInfo');
  let html = `<div class="comp-name" style="color:${comp.color}">${info.name}</div>`;
  Object.entries(info).forEach(([k,v])=>{
    if(k==='name') return;
    html += `<div class="comp-row"><span class="comp-key">${k}</span><span class="comp-val">${v}</span></div>`;
  });
  el.innerHTML = html;
}

